---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Maxfiylik siyosati — Kelajagim"
  description="Kelajagim ilovasining maxfiylik siyosati: qanday ma'lumotlar to'planadi, saqlanadi va foydalanuvchi huquqlari."
>
  <Header />
  <main class="py-16 sm:py-24">
    <div class="container-content mx-auto max-w-prose">
      <h1>Maxfiylik siyosati</h1>

      <section class="mt-10">
        <h2 class="text-xl">1. To'planadigan ma'lumotlar</h2>
        <p class="mt-3 text-inkSecondary">
          Kutish ro'yxatiga yozilish jarayonida biz sizning telefon raqamingizni to'playmiz.
        </p>
        <p class="mt-3 text-inkSecondary">[TODO: to'ldiriladi]</p>
      </section>

      <section class="mt-10">
        <h2 class="text-xl">2. Ma'lumotlarni saqlash</h2>
        <p class="mt-3 text-inkSecondary">
          Ma'lumotlar Supabase infratuzilmasida, Yevropa Ittifoqi (EU) mintaqasidagi
          serverlarda saqlanadi.
        </p>
        <p class="mt-3 text-inkSecondary">[TODO: to'ldiriladi]</p>
      </section>

      <section class="mt-10">
        <h2 class="text-xl">3. Foydalanuvchi huquqlari</h2>
        <p class="mt-3 text-inkSecondary">[TODO: to'ldiriladi]</p>
      </section>

      <section class="mt-10">
        <h2 class="text-xl">4. Bog'lanish</h2>
        <p class="mt-3 text-inkSecondary">
          Savollar bo'yicha: <a href="mailto:info@kelajagim.uz" class="text-primary">info@kelajagim.uz</a>
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Base>
