---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problems from '../components/Problems.astro';
import Tracks from '../components/Tracks.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MockExam from '../components/MockExam.astro';
import Schools from '../components/Schools.astro';
import Pricing from '../components/Pricing.astro';
import Methodology from '../components/Methodology.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Kelajagim — Prezident maktabiga tayyorgarlik ilovasi"
  description="4–6-sinf o'quvchilari uchun Prezident va Ijod maktablari kirish imtihonlariga tizimli tayyorgarlik: video darslar, testlar va real imtihon formatidagi mock sinovlar."
>
  <Header />
  <main>
    <Hero />
    <Problems />
    <Tracks />
    <HowItWorks />
    <MockExam />
    <Schools />
    <Pricing />
    <Methodology />
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</Base>
