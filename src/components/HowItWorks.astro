---
const steps = [
  {
    title: 'Baholash testi',
    text: 'Farzandingiz qisqa diagnostik testdan o\'tadi va joriy bilim darajasi aniqlanadi.',
  },
  {
    title: "Shaxsiy o'quv dasturi",
    text: "Natijaga qarab video darslar, nazariya va mashqlardan iborat dastur tuziladi. Har bir bob 70% natija bilan ochib boriladi.",
  },
  {
    title: 'Prezident mock imtihon',
    text: 'Real imtihon formatida sinov: ikki blok, umumiy taymer va batafsil natija tahlili.',
  },
];
---

<section class="py-16 sm:py-24">
  <div class="container-content">
    <h2 class="text-center" data-reveal>Qanday ishlaydi?</h2>

    <div class="relative mt-12 grid gap-8 sm:grid-cols-3">
      <div
        class="absolute left-0 right-0 top-6 hidden h-px bg-line sm:block"
        aria-hidden="true"
      >
      </div>

      {steps.map((step, index) => (
        <div class="relative flex flex-col items-center text-center sm:items-center" data-reveal>
          <span
            class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-primary text-lg font-bold text-white"
          >
            {index + 1}
          </span>
          <h3 class="mt-4 text-lg font-bold text-ink">{step.title}</h3>
          <p class="mt-2 text-inkSecondary">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
