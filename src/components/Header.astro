---
const navLinks = [
  { href: '#imkoniyatlar', label: 'Imkoniyatlar' },
  { href: '#tariflar', label: 'Tariflar' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="sticky top-0 z-50 border-b border-line/60 bg-surface/80 backdrop-blur-md">
  <div class="container-content flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.png" width="32" height="32" alt="" class="h-8 w-8 rounded-lg" />
      <span class="text-lg font-bold text-ink">Kelajagim</span>
    </a>

    <nav class="hidden md:block" aria-label="Asosiy navigatsiya">
      <ul class="flex items-center gap-8">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-inkSecondary transition-colors hover:text-primary"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href="#waitlist"
      class="min-h-[44px] rounded-pill bg-primary px-5 py-2.5 text-sm font-bold text-white transition-opacity hover:opacity-90 flex items-center"
    >
      Ro'yxatga yozilish
    </a>
  </div>
</header>
